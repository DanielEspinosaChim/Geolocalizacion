# Copia este archivo a .env.local (no se versiona)

# Base de la API (en prod es mismo origen: /api)
VITE_API_BASE_URL=/api

# Dev: a dónde reenvía Vite el proxy de /api (backend FastAPI local)
VITE_API_PROXY=http://localhost:8080

# Fase 1 — Firebase (config pública, separada por entorno)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
